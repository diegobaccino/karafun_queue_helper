{
  "name": "karafun-queue-display",
  "version": "1.0.0",
  "description": "KaraFun Queue Display for Vertical Monitor",
  "main": "main.js",
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --debug",
    "build": "electron-builder --win portable",
    "build-installer": "electron-builder --win nsis portable",
    "build-all": "electron-builder --win"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.karafun.queue-display",
    "productName": "KaraFun Queue Display",
    "directories": {
      "buildResources": "assets",
      "output": "portable"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "portable": {
      "artifactName": "${productName}-v${version}.exe"
    }
  }
}
