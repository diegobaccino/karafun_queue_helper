# Configuration file for KaraFun Queue Display

# KaraFun Server Settings
# ========================

# The IP address or hostname of your KaraFun machine
# Examples: 192.168.1.100, karafun.local, localhost
KARAFUN_SERVER_IP=localhost

# The port KaraFun API is running on (default is 8080)
KARAFUN_SERVER_PORT=8080

# Complete URL (optional - if set, overrides IP and PORT above)
# KARAFUN_API_URL=http://192.168.1.100:8080

# Display Settings
# ========================

# How often to poll the queue (in milliseconds)
# Default: 3000 (3 seconds)
POLL_INTERVAL=3000

# Maximum number of songs to display in the queue before showing "+more" message
# Default: 8
MAX_QUEUE_ITEMS=8

# Window Settings
# ========================

# Window width for vertical monitor (default: 1080)
WINDOW_WIDTH=1080

# Window height for vertical monitor (default: 1920)
WINDOW_HEIGHT=1920

# Start in fullscreen mode (true/false)
START_FULLSCREEN=false

# UI Settings
# ========================

# Show album covers (true/false)
SHOW_ALBUM_COVERS=true

# Show "Added by" information (true/false)
SHOW_ADDED_BY=true

# Theme brightness (0-100)
# Default: 100 (maximum brightness)
BRIGHTNESS=100

# Debug Settings
# ========================

# Enable developer tools on startup (true/false)
ENABLE_DEV_TOOLS=true

# Log API responses to console (true/false)
DEBUG_API=false
